# YALI Environment Variables — copy to .env and fill in your keys

# Groq API — FREE at console.groq.com (required for all agents)
GROQ_API_KEY=your_groq_api_key_here

# Gemini 2.0 Flash — FREE at aistudio.google.com (finance + web search)
# 1,500 req/day, Google Search grounding built-in
GEMINI_API_KEY=your_gemini_api_key_here

# Cloudflare Tunnel — optional, for fixed public URL
# Leave empty to get a random trycloudflare.com URL (no account needed)
# Get token at dash.cloudflare.com > Zero Trust > Tunnels
CLOUDFLARE_TUNNEL_TOKEN=

# Info APIs (all free tier)
NEWS_API_KEY=your_newsapi_key_here
OPENWEATHER_API_KEY=your_openweathermap_key_here
OPENCAGE_API_KEY=your_opencage_key_here
HUGGINGFACE_API_KEY=your_huggingface_token_here

# Gmail (for email sending via YALI)
GMAIL_ADDRESS=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here

# User identity
USER_NAME=Your Name
USER_EMAIL=your_email@gmail.com
